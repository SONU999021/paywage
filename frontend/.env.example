# Local dev — Vite proxies /api to localhost:5000
VITE_API_URL=http://localhost:5000/api

# ── Vercel (required) ──────────────────────────────────────────────
# Copy your Railway BACKEND public domain (Settings → Networking → Generate Domain)
# Do NOT use your Vercel URL here.
RAILWAY_API_URL=https://YOUR-BACKEND-SERVICE.up.railway.app

# Optional — baked into build for direct API calls (not needed on Vercel if using /api proxy)
# VITE_API_URL=https://YOUR-BACKEND-SERVICE.up.railway.app/api
