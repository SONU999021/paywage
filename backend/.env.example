DATABASE_URL="postgresql://postgres:password@localhost:5432/paywager?schema=public"

# Required — use random strings at least 32 characters in production
JWT_SECRET="change-me-to-a-long-random-secret-32chars"
JWT_REFRESH_SECRET="change-me-to-another-long-random-secret"

JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=5000
NODE_ENV=development

# Comma-separated frontend URLs (add your Vercel URL)
FRONTEND_URL="http://localhost:5173,https://your-app.vercel.app"

# Set automatically on Railway when you generate a domain
# RAILWAY_PUBLIC_DOMAIN=backend-production-fa482.up.railway.app
