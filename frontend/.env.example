# On Vercel: leave unset OR use /api — the serverless proxy forwards to Railway.
# On Railway frontend Docker: uses /api via server.mjs proxy.
# Direct backend URL (only if frontend is NOT on Vercel/Railway static host):
VITE_API_URL=https://backend-production-fa482.up.railway.app/api

# Vercel serverless proxy target (optional — has a built-in default):
# RAILWAY_API_URL=https://backend-production-fa482.up.railway.app
